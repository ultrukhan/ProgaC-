using System;
using System.Collections;
using System.Collections.Generic;

namespace Sr1 
{
    class Book 
    { 
        public int Id { get; set; }
        public string Author { get; set; }
        public string Name { get; set; }
        public double Price { get; set; }

        public Book(int id, string author, string name, double price)
        {
            Id = id;
            Author = author;
            Name = name;
            Price = price;
        }
        public Book() : this(new int(), " ", " ", new double()) { }
        public override string ToString()
        {
            return $"Book: book id {Id}, author {Author}, book name {Name}, prise {Price}";
        }
    }
    class Customer
    {
        public string Surname { get; set; }
        public int RegNum { get; set; }
        public string Country { get; set; }

        public Customer(string surname, int regNum, string country)
        {
            Surname = surname;
            RegNum = regNum;
            Country = country;
        }
        public Customer() : this(" ", new int(), " ") { }
        public override string ToString()
        {
            return $"Customer: surname {Surname}, regNum {RegNum}, country {Country}";
        }
    }
    class Order
    {
        public int CRegNum { get; set; }
        public int BookId { get; set; }
        public int NumOfBooks { get; set; }

        public Order(int cRegNum, int bookId, int numOfBooks)
        {
            CRegNum = cRegNum;
            BookId = bookId;
            NumOfBooks = numOfBooks;
        }
        public Order() : this(new int(), new int(), new int()) { }
        public override string ToString()
        {
            return $"Order: regNum  {CRegNum}, book id {BookId}, num of books {NumOfBooks}";
        }
    }

    class Program
    { 
        static void Main(string[] args)
        {
            var books = new List<Book>();
            var customers = new List<Customer>();
            var orders = new List<Order>();

            books.Add(new Book(1, "Author1", "Name1", 100));
            books.Add(new Book(2, "Author2", "Name2", 200));
            books.Add(new Book(3, "Author3", "Name3", 300));
            books.Add(new Book(4, "Author4", "Name4", 400));
            books.Add(new Book(5, "Author2", "Name5", 500));


            customers.Add(new Customer("Surname1", 11, "Country1"));
            customers.Add(new Customer("Surname2", 12, "Country2"));
            customers.Add(new Customer("Surname3", 13, "Country3"));
            customers.Add(new Customer("Surname4", 14, "Country4"));

            orders.Add(new Order(1, 1, 2));
            orders.Add(new Order(1, 2, 3));
            orders.Add(new Order(2, 1, 1));
            orders.Add(new Order(3, 4, 5));
            orders.Add(new Order(4, 3, 1));
            orders.Add(new Order(4, 5, 2));

            Console.WriteLine("Task A");
            foreach (var b in books)
            {
                int numOfBooks = 0;
                foreach (var ord in orders)
                {
                    if (b.Id == ord.BookId)
                    {
                        numOfBooks += ord.NumOfBooks;
                    }
                }
                double totalPrice = numOfBooks * b.Price;
                Console.WriteLine($"{b.Name} | {b.Author} | {totalPrice}");
            }

            Console.WriteLine("Task B");
            var sameAuthor = new Dictionary<string, double>();
            foreach (var b in books)
            {
                if (!sameAuthor.ContainsKey(b.Author))
                {
                    sameAuthor.Add(b.Author, 0);
                }
            }
            foreach (var b in books)
            {
                if (sameAuthor.ContainsKey(b.Author))
                {
                    foreach (var o in orders)
                    {
                        if (b.Id == o.BookId)
                        {
                            sameAuthor[b.Author] += o.NumOfBooks * b.Price;
                        }
                    }
                }

            }
            foreach (var sa in sameAuthor)
            {
                Console.WriteLine($"{sa.Key} | {sa.Value}");
            }
            
        }
    }
}
